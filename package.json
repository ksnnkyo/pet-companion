{
  "name": "pet-companion",
  "version": "1.0.0",
  "description": "AI Desktop Pet Companion - 情感交互桌面宠物",
  "main": "main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build:renderer": "vite build",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "electron-store": "^8.1.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.petcompanion.app",
    "productName": "PetCompanion",
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "build/icon.icns"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/dist/**/*"
    ]
  }
}
